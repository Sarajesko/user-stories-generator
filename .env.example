# MySQL (XAMPP local)
DATABASE_URL=mysql+pymysql://root@127.0.0.1:3306/user_stories_db

# Azure OpenAI (mismas variables que en el entregable 2)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
TEMPERATURE=0.1
MAX_TOKENS=2048
# Minimo recomendado 1024; generar varias tareas con JSON estructurado necesita mas tokens
TOP_P=1.0
